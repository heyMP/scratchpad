{
  "name": "@heymp/scratchpad",
  "description": "Run TS/JS snippets in a locally",
  "version": "1.0.0-next.21",
  "main": "src/lib/index.js",
  "module": "src/lib/index.js",
  "type": "module",
  "bin": {
    "scratchpad": "bin/cli.js"
  },
  "exports": {
    ".": {
      "types": "./src/lib/index.d.ts.js",
      "default": "./src/lib/index.js"
    }
  },
  "files": [
    "bin/cli.js",
    "templates/**",
    "src/**",
    "types.d.ts"
  ],
  "dependencies": {
    "@commander-js/extra-typings": "^12.1.0",
    "commander": "^12.0.0",
    "esbuild": "^0.25.10",
    "playwright": "^1.44.1"
  },
  "scripts": {
    "setup": "yarn install --ignore-scripts && yarn allow-scripts",
    "preinstall": "echo 'Do not run yarn install directly. Use: yarn setup' && exit 1",
    "build": "tsc",
    "build:watch": "tsc -w",
    "test": "yarn build && node --test src/**/*.test.js",
    "release": "yarn changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.1",
    "@lavamoat/allow-scripts": "^5.0.2",
    "@types/node": "^22.1.0",
    "typescript": "^5.5.4"
  },
  "publishConfig": {
    "access": "public"
  },
  "lavamoat": {
    "allowScripts": {
      "esbuild#0.25.10": true
    }
  }
}
